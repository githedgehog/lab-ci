	hhfab diagram --format mermaid --output env-ci-1.l/diagrams/spine-leaf/env-ci-1-spine-leaf.mermaid
	if command -v dot >/dev/null; then dot -Tsvg -Gbgcolor=transparent env-ci-1.l/diagrams/spine-leaf/env-ci-1-spine-leaf.dot -o env-ci-1.l/diagrams/spine-leaf/env-ci-1-spine-leaf.dot.svg; fi
	if command -v drawio >/dev/null; then drawio --export --format svg --output env-ci-1.l/diagrams/spine-leaf/env-ci-1-spine-leaf.default.drawio.svg env-ci-1.l/diagrams/spine-leaf/env-ci-1-spine-leaf.drawio; fi
	if command -v drawio >/dev/null; then drawio --export --format svg --output env-ci-1.l/diagrams/spine-leaf/env-ci-1-spine-leaf.cisco.drawio.svg env-ci-1.l/diagrams/spine-leaf/env-ci-1-spine-leaf-cisco.drawio; fi
	if command -v drawio >/dev/null; then drawio --export --format svg --output env-ci-1.l/diagrams/spine-leaf/env-ci-1-spine-leaf.hedgehog.drawio.svg env-ci-1.l/diagrams/spine-leaf/env-ci-1-spine-leaf-hedgehog.drawio; fi
	if command -v mmdc >/dev/null; then mmdc -i env-ci-1.l/diagrams/spine-leaf/env-ci-1-spine-leaf.mermaid -o env-ci-1.l/diagrams/spine-leaf/env-ci-1-spine-leaf.mermaid.svg -t default -b transparent -p ~/lab/envs/puppeteer-config.json || echo "Warning: mmdc failed (Chrome missing for Puppeteer? Run: npx puppeteer browsers install chrome@131.0.6778.204)"; fi
	@echo "COMPLETED: env-ci-1.l spine-leaf-gateway diagrams"

# vlab auto-generated topologies (matches CI configurations)
update-diagrams-vlab-spine-leaf:
	@echo "Generating diagrams for vlab: spine-leaf"
	mkdir -p env-ci-1.l/diagrams/vlab-spine-leaf
	hhfab init --dev -f
	hhfab vlab gen -v
	hhfab diagram --format drawio --style default --output env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf.drawio
	hhfab diagram --format drawio --style cisco --output env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf-cisco.drawio
	hhfab diagram --format drawio --style hedgehog --output env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf-hedgehog.drawio
	hhfab diagram --format dot    --output env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf.dot
	hhfab diagram --format mermaid --output env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf.mermaid
	if command -v dot >/dev/null; then dot -Tsvg -Gbgcolor=transparent env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf.dot -o env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf.dot.svg; fi
	if command -v drawio >/dev/null; then drawio --export --format svg --output env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf.default.drawio.svg env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf.drawio; fi
	if command -v drawio >/dev/null; then drawio --export --format svg --output env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf.cisco.drawio.svg env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf-cisco.drawio; fi
	if command -v drawio >/dev/null; then drawio --export --format svg --output env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf.hedgehog.drawio.svg env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf-hedgehog.drawio; fi
	if command -v mmdc >/dev/null; then mmdc -i env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf.mermaid -o env-ci-1.l/diagrams/vlab-spine-leaf/vlab-spine-leaf.mermaid.svg -t default -b transparent -p ~/lab/envs/puppeteer-config.json || echo "Warning: mmdc failed"; fi
	@echo "COMPLETED: vlab spine-leaf diagrams"

