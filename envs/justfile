update-diagrams-vlab-mesh:
	@echo "Generating diagrams for vlab: mesh"
	mkdir -p env-ci-1.l/diagrams/vlab-mesh
	hhfab init --dev -f
	hhfab vlab gen -v --mesh-links-count=3
	hhfab diagram --format drawio --style default --output env-ci-1.l/diagrams/vlab-mesh/vlab-mesh.drawio
	hhfab diagram --format drawio --style cisco --output env-ci-1.l/diagrams/vlab-mesh/vlab-mesh-cisco.drawio
	hhfab diagram --format drawio --style hedgehog --output env-ci-1.l/diagrams/vlab-mesh/vlab-mesh-hedgehog.drawio
	hhfab diagram --format dot    --output env-ci-1.l/diagrams/vlab-mesh/vlab-mesh.dot
	hhfab diagram --format mermaid --output env-ci-1.l/diagrams/vlab-mesh/vlab-mesh.mermaid
	if command -v dot >/dev/null; then dot -Tsvg -Gbgcolor=transparent env-ci-1.l/diagrams/vlab-mesh/vlab-mesh.dot -o env-ci-1.l/diagrams/vlab-mesh/vlab-mesh.dot.svg; fi
	if command -v drawio >/dev/null; then drawio --export --format svg --output env-ci-1.l/diagrams/vlab-mesh/vlab-mesh.default.drawio.svg env-ci-1.l/diagrams/vlab-mesh/vlab-mesh.drawio; fi
	if command -v drawio >/dev/null; then drawio --export --format svg --output env-ci-1.l/diagrams/vlab-mesh/vlab-mesh.cisco.drawio.svg env-ci-1.l/diagrams/vlab-mesh/vlab-mesh-cisco.drawio; fi
	if command -v drawio >/dev/null; then drawio --export --format svg --output env-ci-1.l/diagrams/vlab-mesh/vlab-mesh.hedgehog.drawio.svg env-ci-1.l/diagrams/vlab-mesh/vlab-mesh-hedgehog.drawio; fi
